APP_NAME="Recruitment System"
APP_ENV=production
APP_KEY=
# ganti ke https://karir.nusantaraabadijaya.com saat deploy
APP_URL=http://localhost
APP_DEBUG=false
APP_TIMEZONE=Asia/Makassar

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file
APP_PREVIOUS_KEYS=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=karir
DB_USERNAME=karir
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root-secret
DB_FORWARD_PORT=3307

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=karir_cache

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Microsoft 365 SMTP option A: only works when SMTP AUTH basic is explicitly enabled
# by the Exchange/Microsoft 365 administrator for this mailbox.
# Production values: MAIL_HOST=smtp.office365.com, MAIL_PORT=587, MAIL_ENCRYPTION=tls.
# If SMTP AUTH basic is disabled, use Microsoft Graph API mail sending (OAuth2)
# or a production SMTP relay such as SendGrid/Mailgun instead.
MAIL_MAILER=graph
MAIL_SCHEME=null
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@nusantaraabadijaya.com"
MAIL_FROM_NAME="Sistem Rekrutmen Nusantara Abadi Jaya"

# Microsoft Graph outbound notifications (separate Azure App Registration / Mail.Send)
MAIL_GRAPH_SENDER_TENANT_ID=
MAIL_GRAPH_SENDER_CLIENT_ID=
MAIL_GRAPH_SENDER_CLIENT_SECRET=
MAIL_GRAPH_SENDER_MAILBOX=no-reply@nusantaraabadijaya.com

# DocuSeal self-hosted API. Generate the API key from this self-hosted instance:
# Settings > API in DocuSeal. Do not use a DocuSeal Cloud API key here.
DOCUSEAL_API_URL=http://145.79.12.57:3000/api
DOCUSEAL_API_KEY=
DOCUSEAL_WEBHOOK_SECRET=

# Microsoft Graph API / Azure App Registration for calendar, mailbox, and SharePoint flows.
# SharePoint candidate-data sync is configured but should be tested after DocuSeal is working.
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_CALENDAR_USER_EMAIL=
MICROSOFT_GRAPH_RECRUITMENT_MAILBOX=

# Microsoft Graph inbound email applicant intake (separate Azure App Registration / Mail.Read)
MAIL_GRAPH_INTAKE_TENANT_ID=
MAIL_GRAPH_INTAKE_CLIENT_ID=
MAIL_GRAPH_INTAKE_CLIENT_SECRET=
MAIL_GRAPH_INTAKE_MAILBOX=karir@nusantaraabadijaya.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

POSTMARK_TOKEN=
RESEND_KEY=
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

VITE_APP_NAME="${APP_NAME}"
